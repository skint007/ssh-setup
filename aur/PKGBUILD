# Maintainer: skint007 <archlinux.repose742@passmail.net>
# Built from source by the `paw` personal repo CI (not the official AUR).
pkgname=ssh-setup
pkgver=0.0.0
pkgrel=1
pkgdesc="Generate, rotate, and install SSH keys and manage ~/.ssh/config entries"
arch=('any')
url="https://github.com/skint007/ssh-setup"
license=('MIT')
depends=('bash' 'openssh')
makedepends=('git')
conflicts=('ssh-setup-bin' 'ssh-setup-git')
source=("git+https://github.com/skint007/ssh-setup.git")
sha256sums=('SKIP')

pkgver() {
    cd "$srcdir/ssh-setup"
    # No version string in the project, so derive one: latest tag (if any) plus a
    # monotonic git suffix, e.g. 0.0.0.r12.a1b2c3d. Every commit bumps the version,
    # so a paw rebuild always reads as an update.
    local v r h
    v=$(git describe --tags --abbrev=0 2>/dev/null | sed 's/^v//')
    [ -n "$v" ] || v=0.0.0
    r=$(git rev-list --count HEAD)
    h=$(git rev-parse --short=7 HEAD)
    printf '%s.r%s.%s' "$v" "$r" "$h"
}

package() {
    cd "$srcdir/ssh-setup"
    install -Dm755 ssh-setup.sh "$pkgdir/usr/bin/ssh-setup"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
